# Iron Exiles - Auth Service Environment Configuration
# Copy to .env and adjust values as needed.
# Default values work for local Docker Compose development.

# PostgreSQL
DB_NAME=iron_exiles_auth
DB_USER=auth_service
DB_PASSWORD=dev_password
DB_PORT_EXTERNAL=5432

# Redis
REDIS_PORT_EXTERNAL=6379

# Auth Service
AUTH_PORT_EXTERNAL=3000
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=24h
AUTH_MODE_ENABLED=true

# Password hashing (lower for dev speed, 12+ for production)
BCRYPT_ROUNDS=12

# Rate limiting (BR-3: 5 attempts per 60s window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=5
