{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Play EmptySector",
      "type": "node-terminal",
      "request": "launch",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File Scripts/Run-UnityGame.ps1",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Local Multiplayer Dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File Scripts/Launch-LocalMultiplayerDev.ps1",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Run Tests",
      "type": "node-terminal",
      "request": "launch",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File Scripts/Run-UnityTests.ps1",
      "cwd": "${workspaceFolder}"
    }
  ]
}
